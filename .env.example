# TMDB API Key
# Get your free API key at https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=your_api_key_here

# Stage 2 feature flag — switch between the legacy canvas-2D ForceGraph
# renderer (false) and the new Pixi WebGL StarfieldCanvas (true). The
# flag goes away in Stage 3 when Pixi becomes the only renderer.
VITE_USE_PIXI=false
